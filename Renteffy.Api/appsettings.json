{
  "JwtSettings": {
    "ExpiryMinutes": 30,
    "Issuer": "Renteffy.Api",
    "Audience": "Renteffy.Client",
    "RefreshTokenDays": 30
  },
  "FileStorage": {
    "FolderName": "RenteffyUploads",
    "PublicBaseUrl": "/uploads"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
